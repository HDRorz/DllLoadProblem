<?xml version="1.0" encoding="utf-8" ?>
<log4net debug="false">
  <root>
    <appender-ref ref="ErrorLog"/>
    <appender-ref ref="InfoLog"/>
    <appender-ref ref="WarnLog"/>
    <!--<appender-ref ref="DebugLog" />-->
    <appender-ref ref="AsyncDebugAppender"/>
  </root>
  
  <appender name="AsyncDebugAppender" type="Easy.Logger.AsyncBufferingForwardingAppender, Easy.Logger">
    <lossy value="false"/>
    <bufferSize value="512"/>
    <idleTime value="200"/>
    <fix value="268"/>

    <appender-ref ref="DebugLog"/>

    <filter type="log4net.Filter.LevelRangeFilter">
      <param name="LevelMin" value="DEBUG"/>
      <param name="LevelMax" value="DEBUG"/>
    </filter>
  </appender>

  <appender name="ErrorLog" type="log4net.Appender.RollingFileAppender">
    <file value="Log\ErrorLog\"/>
    <appendToFile value="true"/>
    <rollingStyle value="Date"/>
    <param name="DatePattern" value="&quot;ErrorLog&quot;_yyyyMMdd&quot;.txt&quot;"/>
    <param name="StaticLogFileName" value="false"/>
    <layout type="log4net.Layout.PatternLayout">
      <conversionPattern value="%date [%t] %-5p - 错误描述：%message%newline"/>
    </layout>
    <filter type="log4net.Filter.LevelRangeFilter">
      <param name="LevelMin" value="ERROR"/>
      <param name="LevelMax" value="ERROR"/>
    </filter>
  </appender>

  <appender name="InfoLog" type="log4net.Appender.RollingFileAppender">
    <file value="Log\InfoLog\"/>
    <appendToFile value="true"/>
    <rollingStyle value="Date"/>
    <param name="RollingStyle" value="Date"/>
    <param name="DatePattern" value="&quot;InfoLog&quot;_yyyyMMdd&quot;.txt&quot;"/>
    <param name="StaticLogFileName" value="false"/>
    <layout type="log4net.Layout.PatternLayout">
      <conversionPattern value="%date [%t] %-5p - 信息描述：%message%newline"/>
    </layout>
    <filter type="log4net.Filter.LevelRangeFilter">
      <param name="LevelMin" value="INFO"/>
      <param name="LevelMax" value="INFO"/>
    </filter>
  </appender>

  <appender name="WarnLog" type="log4net.Appender.RollingFileAppender">
    <file value="Log\WarnLog\"/>
    <appendToFile value="true"/>
    <rollingStyle value="Date"/>
    <param name="RollingStyle" value="Date"/>
    <param name="DatePattern" value="&quot;WarnLog&quot;_yyyyMMdd&quot;.txt&quot;"/>
    <param name="StaticLogFileName" value="false"/>
    <layout type="log4net.Layout.PatternLayout">
      <conversionPattern value="%date [%t] %-5p - 信息描述：%message%newline"/>
    </layout>
    <filter type="log4net.Filter.LevelRangeFilter">
      <param name="LevelMin" value="WARN"/>
      <param name="LevelMax" value="WARN"/>
    </filter>
  </appender>

  <appender name="DebugLog" type="log4net.Appender.RollingFileAppender">
    <file value="Log\DebugLog\"/>
    <appendToFile value="true"/>
    <rollingStyle value="Date"/>
    <param name="RollingStyle" value="Date"/>
    <param name="DatePattern" value="&quot;DebugLog&quot;_yyyyMMdd&quot;.txt&quot;"/>
    <param name="StaticLogFileName" value="false"/>
    <layout type="log4net.Layout.PatternLayout">
      <conversionPattern value="%date [%t] %-5p - 信息描述：%message%newline"/>
    </layout>
    <filter type="log4net.Filter.LevelRangeFilter">
      <param name="LevelMin" value="DEBUG"/>
      <param name="LevelMax" value="DEBUG"/>
    </filter>
  </appender>
</log4net>